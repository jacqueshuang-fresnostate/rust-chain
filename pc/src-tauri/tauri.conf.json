{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hippo Exchange",
  "version": "0.1.0",
  "identifier": "com.hippo.exchange",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1610",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hippo Exchange",
        "width": 1600,
        "minWidth": 1600,
        "minHeight": 900,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://www.hippoweb3.net/update/{{target}}/{{current_version}}"
      ],
      "pubkey": "YOUR_PUBLIC_KEY_HERE"
    }
  }
}
