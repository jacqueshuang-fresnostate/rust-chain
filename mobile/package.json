{
  "name": "hippo-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "tauri": "tauri",
    "tauri:desktop": "tauri dev",
    "tauri:android:init": "node scripts/run-android-tauri.mjs init --ci --skip-targets-install",
    "tauri:android:dev": "node scripts/run-android-tauri.mjs dev",
    "tauri:android:build": "node scripts/run-android-tauri.mjs build",
    "tauri:ios:init": "node scripts/run-ios-tauri.mjs init --ci --skip-targets-install",
    "tauri:ios:dev": "node scripts/run-ios-tauri.mjs dev",
    "tauri:ios:build": "node scripts/run-ios-tauri.mjs build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "axios": "^1.6.0",
    "lightweight-charts": "^5.2.0",
    "lucide-vue-next": "^0.563.0",
    "pinia": "^2.1.0",
    "qrcode": "^1.5.4",
    "vue": "^3.4.0",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0"
  }
}
