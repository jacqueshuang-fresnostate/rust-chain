{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hippo Mobile",
  "version": "0.1.0",
  "identifier": "com.hippo.exchange.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1611",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hippo Mobile",
        "width": 430,
        "height": 860,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}

